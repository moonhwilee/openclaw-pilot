{
  "schema_version": "pilot.conv_request.v0",
  "anchor": {
    "id": "document-strategy-fixture",
    "path": "evidence-packet.json",
    "description": "Document strategy verification fixture has known bounded findings."
  },
  "findings": [
    {
      "id": "missing-support-note",
